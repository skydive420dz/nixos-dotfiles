{
  "$schema": "https://githubusercontent.com",
  "positionX": "right",
  "positionY": "top",
  "layer": "top",
  "cssPriority": "user",
  "control-center-width": 450,
  "control-center-margin-top": 15,
  "control-center-margin-bottom": 16,
  "control-center-margin-right": 15,
  "control-center-margin-left": 15,
  "fit-to-screen": true,
  "notification-window-width": 400,
  "notification-icon-size": 40,
  "notification-body-image-height": 500,
  "notification-body-image-width": 500,
  "notification-inline-replies": true,
  "notification-2fa-action": false,
  "timeout": 3,
  "timeout-low": 2,
  "timeout-critical": 6,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": false,
  "script-fail-notify": true,
  "widgets": [
    "mpris",
    "dnd",
    "notifications",
    "buttons-grid"
  ],
  "widget-config": {
    "dnd": {
      "text": "Do not disturb"
    },
    "mpris": {
      "image-size": 100,
      "image-radius": 12,
      "autohide": false
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰂯",
          "command": "kitty --class bluetui -T bluetui -e bluetui; swaync-client -cp"
        },
        {
          "label": "",
          "command": "kitty --class btop -T btop -e btop; swaync-client -cp"
        },
        {
          "label": "󰍹",
          "command": "kitty --class nvtop -T nvtop -e nvtop; swaync-client -cp"
        },
        {
          "label": "",
          "command": "swaync-client -cp; wlogout"
        }
      ]
    }
  }
}
