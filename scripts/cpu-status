#!/usr/bin/env bash

# Change 'thermal_zone0' to whatever number you found in step 1
TEMP_RAW=$(cat /sys/class/thermal/thermal_zone0/temp)
CPU_TEMP=$((TEMP_RAW / 1000))

# Get CPU usage (0-100)
CPU_UTIL=$(top -bn1 | grep "Cpu(s)" | awk '{print 100 - $8}' | cut -d. -f1)

# Default to 0 if empty
[ -z "$CPU_TEMP" ] && CPU_TEMP=0

# Output JSON with percentage for icon logic
echo "{\"text\": \"$CPU_UTIL% $CPU_TEMP°C\", \"percentage\": $CPU_TEMP, \"tooltip\": \"Usage: $CPU_UTIL% | Temp: $CPU_TEMP°C\"}"
