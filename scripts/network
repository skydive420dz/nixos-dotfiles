#!/usr/bin/env bash
# Integrated Wi-Fi Selector for Hyprland
# Requires: fzf, networkmanager (nmcli)

LAVENDER="rgb(b4befe)"
MAUVE="rgb(cba6f7)"
TIMEOUT=5

# Native Hyprland notification helper
notify() {
        hyprctl notify 1 2000 "$1" "$2"
}

switch_on() {
        state=$(nmcli radio wifi)
        if [[ $state == "enabled" ]]; then return 0; fi

        nmcli radio wifi on
        notify "$LAVENDER" "Enabling Wi-Fi..."
        sleep 2
}

get_networks() {
        nmcli device wifi rescan >/dev/null 2>&1

        # Simple spinner/status
        for ((i = 1; i <= TIMEOUT; i++)); do
                echo -ne "\rScanning... ($i/$TIMEOUT)"
                LIST=$(nmcli --terse --fields "IN-USE,SSID,BARS,SECURITY" device wifi list)
                if [[ -n $LIST ]]; then break; fi
                sleep 1
        done
        echo -e "\n"
}

select_network() {
        # Using fzf to select by SSID
        CHOICE=$(echo "$LIST" | sed 's/^://' | fzf --height 40% --reverse --header "Select Wi-Fi Network" --border sharp)

        if [[ -z $CHOICE ]]; then exit 0; fi

        SSID=$(echo "$CHOICE" | cut -d':' -f1)

        if [[ "$CHOICE" == "*"* ]]; then
                notify "$MAUVE" "Already connected to $SSID"
                exit 0
        fi
}

connect() {
        notify "$LAVENDER" "Connecting to $SSID..."
        if nmcli device wifi connect "$SSID"; then
                notify "$LAVENDER" "Connected to $SSID"
        else
                notify "$MAUVE" "Failed to connect to $SSID"
                exit 1
        fi
}

main() {
        if [[ $1 == "off" ]]; then
                nmcli radio wifi off
                notify "$MAUVE" "Wi-Fi Disabled"
                exit 0
        fi

        switch_on
        get_networks
        select_network
        connect
}

main "$@"
