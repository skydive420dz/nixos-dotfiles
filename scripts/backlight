#!/usr/bin/env bash
#
# Adjust screen brightness with native Hyprland notifications
# Requires: brightnessctl

DEF_VALUE=5
LAVENDER="rgb(b4befe)"

# Native Hyprland notification helper
# icon 1 = info, icon -1 = none
notify_hypr() {
        hyprctl notify 1 1500 "$LAVENDER" "Brightness: $1"
}

case $1 in
up)
        brightnessctl -n set "${2:-$DEF_VALUE}%+" >/dev/null
        ;;
down)
        # Prevents screen from going pitch black (min 1%)
        brightnessctl -n set "${2:-$DEF_VALUE}%-" --min-value=1 >/dev/null
        ;;
*)
        echo "Usage: ${0##*/} {up|down} [value]"
        exit 1
        ;;
esac

# Get the new level to display
CURRENT_LEVEL=$(brightnessctl -m | awk -F ',' '{print $4}')
notify_hypr "$CURRENT_LEVEL"
