#!/usr/bin/env bash
cap=$(cat /sys/class/power_supply/BAT*/capacity 2>/dev/null | head -1)
sta=$(cat /sys/class/power_supply/BAT*/status   2>/dev/null | head -1)
cyc=$(cat /sys/class/power_supply/BAT*/cycle_count 2>/dev/null | head -1)
bat=$(upower -e 2>/dev/null | grep -i battery | grep -iv 'mouse\|keyboard\|headset' | head -1)
pwr=""
tim=""
if [ -n "$bat" ]; then
    info=$(upower -i "$bat" 2>/dev/null)
    pwr=$(echo "$info" | awk '/energy-rate/ {print $2, $3}')
    tim=$(echo "$info" | awk '/time to/ {print $4, $5}')
fi
printf '{"cap":%s,"sta":"%s","cyc":"%s","pwr":"%s","tim":"%s"}\n' \
    "${cap:-100}" "${sta:-Unknown}" "${cyc:-}" "${pwr:-}" "${tim:-}"
