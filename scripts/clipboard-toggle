#!/usr/bin/env bash
set -euo pipefail

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
theme_config="$config_home/theme/current/fuzzel.ini"

if [ ! -r "$theme_config" ]; then
    "$HOME/.config/scripts/theme-select" apply >/dev/null 2>&1 || true
fi

selection=$(cliphist list | fuzzel --config="$theme_config" --dmenu --prompt "Clipboard " || true)

if [[ -n "${selection:-}" ]]; then
    printf '%s' "$selection" | cliphist decode | wl-copy
fi
