EOF
}

write_qutebrowser_theme() {
  prepare_target "$current_dir/qutebrowser.py"
  cat > "$current_dir/qutebrowser.py" <<EOF
# Generated by theme-select from $style.
FLAVOR = "$(hex '.[$style].flavor')"

def setup(c):
    c.colors.completion.category.bg = "$(hex '.[$style].semantic.background')"
    c.colors.completion.category.border.bottom = "$(hex '.[$style].semantic.surface')"
    c.colors.completion.category.border.top = "$(hex '.[$style].semantic.surface')"
    c.colors.completion.category.fg = "$(hex '.[$style].semantic.accent')"

    c.colors.completion.even.bg = "$(hex '.[$style].semantic.background')"
    c.colors.completion.odd.bg = "$(hex '.[$style].semantic.surface')"
    c.colors.completion.fg = "$(hex '.[$style].semantic.foreground')"
    c.colors.completion.item.selected.bg = "$(hex '.[$style].semantic.surfaceStrong')"
    c.colors.completion.item.selected.fg = "$(hex '.[$style].semantic.foreground')"
    c.colors.completion.match.fg = "$(hex '.[$style].semantic.warning')"

    c.colors.tabs.even.bg = "$(hex '.[$style].semantic.surface')"
    c.colors.tabs.odd.bg = "$(hex '.[$style].semantic.surface')"
    c.colors.tabs.even.fg = "$(hex '.[$style].semantic.foreground')"
    c.colors.tabs.odd.fg = "$(hex '.[$style].semantic.foreground')"
    c.colors.tabs.selected.even.bg = "$(hex '.[$style].semantic.background')"
    c.colors.tabs.selected.odd.bg = "$(hex '.[$style].semantic.background')"
    c.colors.tabs.selected.even.fg = "$(hex '.[$style].semantic.accent')"
    c.colors.tabs.selected.odd.fg = "$(hex '.[$style].semantic.accent')"

    c.colors.statusbar.normal.bg = "$(hex '.[$style].semantic.background')"
    c.colors.statusbar.normal.fg = "$(hex '.[$style].semantic.foreground')"
    c.colors.statusbar.insert.bg = "$(hex '.[$style].semantic.success')"
    c.colors.statusbar.insert.fg = "$(hex '.[$style].semantic.selectionForeground')"
    c.colors.statusbar.command.bg = "$(hex '.[$style].semantic.background')"
    c.colors.statusbar.command.fg = "$(hex '.[$style].semantic.foreground')"
EOF
}

