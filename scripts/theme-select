#!/usr/bin/env bash
set -euo pipefail

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)"
repo_root="$(CDPATH= cd -- "$script_dir/.." && pwd -P)"
support_dir="$script_dir/theme-select.d"
styles_json="$repo_root/theme/styles.json"

config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
theme_home="$config_home/theme"
state_file="$theme_home/current-style"
current_dir="$theme_home/current"
jq_bin="${JQ:-}"

source "$support_dir/core.sh"
source "$support_dir/state.sh"
source "$support_dir/consumers.sh"

for generator in "$support_dir"/generators/*.sh; do
  source "$generator"
done

write_all_outputs() {
  write_quickshell_theme
  write_kitty_theme
  write_btop_theme
  write_bat_theme
  write_aerc_styleset
  write_mako_config
  write_qutebrowser_theme
  write_fuzzel_config
  write_starship_config
  write_tmux_config
  write_emacs_theme
  write_gtk_config
  write_qt_config
  write_kdeglobals
  write_env
}

need_jq
mkdir -p "$theme_home" "$current_dir"

action="${1:-apply}"
case "$action" in
  current) current_style; exit 0 ;;
  list) jq -r 'keys[]' "$styles_json"; exit 0 ;;
  -h|--help|help) usage; exit 0 ;;
esac

style="$(select_style "$action")"
if ! style_exists "$style"; then
  printf 'theme-select: unknown style %s\n' "$style" >&2
  usage >&2
  exit 1
fi

printf '%s\n' "$style" > "$state_file"

write_all_outputs
update_session_env

case "$action" in
  apply) ;;
  *) reload_consumers ;;
esac

printf '%s\n' "$style"
