#!/usr/bin/env bash

selected=$(
        {
                # Current main workspace
                printf '%s\n' "$HOME/nixos-dotfiles"

                # Dotfile sub-workspaces worth jumping into
                printf '%s\n' \
                        "$HOME/nixos-dotfiles/config/quickshell" \
                        "$HOME/nixos-dotfiles/config/hypr" \
                        "$HOME/nixos-dotfiles/config/tmux" \
                        "$HOME/nixos-dotfiles/config/yazi" \
                        "$HOME/nixos-dotfiles/home/modules" \
                        "$HOME/nixos-dotfiles/system/modules" \
                        "$HOME/nixos-dotfiles/scripts"

                # Future project buckets
                find "$HOME/projects" "$HOME/src" "$HOME/work" "$HOME/notes" \
                        -mindepth 1 \
                        -maxdepth 2 \
                        -type d \
                        2>/dev/null
        } | sort -u | fzf
)

[ -z "$selected" ] && exit 0

session=$(basename "$selected" | tr '.:' '__')

if ! tmux has-session -t="$session" 2>/dev/null; then
        tmux new-session -ds "$session" -c "$selected"
fi

if [ -n "$TMUX" ]; then
        tmux switch-client -t "$session"
else
        tmux attach -t "$session"
fi
