*.log

# Clean Emacs experiment runtime/cache state belongs outside git.
config/emacs/**/*.elc
config/emacs/auto-save/
config/emacs/auto-save-list/
config/emacs/backups/
config/emacs/eln-cache/
config/emacs/elpa/
config/emacs/history
config/emacs/recentf

